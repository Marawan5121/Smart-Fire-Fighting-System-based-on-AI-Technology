    {
        "id": "parse_gas",
        "type": "function",
        "name": "Extract Gas",
        "func": "var gas = msg.payload.gas || {};\nvar m1 = {payload: gas.mq2 || 0};\nvar m2 = {payload: gas.mq5 || 0};\nvar m3 = {payload: gas.mq6 || 0};\nvar m4 = {payload: gas.mq7 || 0};\nreturn [m1, m2, m3, m4];",
        "outputs": 4,
        "x": 330,
        "y": 60,
        "wires": [["gauge_mq2"], ["gauge_mq5"], ["gauge_mq6"], ["gauge_mq7"]]
    },
    {
        "id": "parse_env",
        "type": "function",
        "name": "Extract Env",
        "func": "var env = msg.payload.env || {};\nvar temp = {payload: parseFloat(env.temp) || 0};\nvar hum = {payload: parseFloat(env.hum) || 0};\nreturn [temp, hum];",
        "outputs": 2,
        "x": 330,
        "y": 120,
        "wires": [["gauge_temp", "chart_temp"], ["gauge_hum"]]
    },
    {
        "id": "parse_motion",
        "type": "function",
        "name": "Extract Motion",
        "func": "var m = msg.payload.motion || {};\nvar tilt = {payload: m.tilt ? '⚠️ TILT DETECTED' : '✅ Level'};\nreturn [tilt];",
        "outputs": 1,
        "x": 330,
        "y": 160,
        "wires": [["text_tilt"]]
    },
    {
        "id": "parse_meta",
        "type": "function",
        "name": "Extract Meta",
        "func": "var meta = msg.payload.meta || {};\nvar rssi = {payload: meta.wifi_rssi || -100};\nvar uptime = {payload: (meta.uptime_s || 0) + 's'};\nvar heap = {payload: ((meta.heap_free || 0) / 1024).toFixed(1) + ' KB'};\nvar mode = {payload: meta.mode || 'UNKNOWN'};\nvar flame = {payload: meta.flame ? '🔥 DETECTED' : '✅ Clear'};\nreturn [rssi, uptime, heap, mode, flame];",
        "outputs": 5,
        "x": 330,
        "y": 200,
        "wires": [["gauge_rssi"], ["text_uptime"], ["text_heap"], ["text_mode"], ["text_flame"]]
    },
    {
        "id": "parse_status",
        "type": "function",
        "name": "Extract Status",
        "func": "var p = msg.payload;\nvar state = {payload: p.state || 'UNKNOWN'};\nvar conf = {payload: ((p.confidence || 0) * 100).toFixed(0) + '%'};\nvar src = {payload: p.source || 'N/A'};\nvar valve = {payload: (p.actions && p.actions.gas_valve) || 'N/A'};\nvar doors = {payload: (p.actions && p.actions.doors) || 'N/A'};\nvar buzzer = {payload: (p.actions && p.actions.buzzer) || 'N/A'};\nvar pump1 = {payload: (p.actions && p.actions.pump1) || 'N/A'};\nvar pump2 = {payload: (p.actions && p.actions.pump2) || 'N/A'};\n\nvar colors = {'SAFE':'#4caf50','GAS_LEAK':'#ff9800','SMOKE':'#9e9e9e','FIRE':'#f44336'};\nstate.ui_control = {color: colors[p.state] || '#ffffff'};\n\nreturn [state, conf, src, valve, doors, buzzer, pump1, pump2];",
        "outputs": 8,
        "x": 330,
        "y": 260,
        "wires": [["text_state"], ["text_conf"], ["text_src"], ["text_valve"], ["text_doors"], ["text_buzzer"], ["text_pump1"], ["text_pump2"]]
    },
    {
        "id": "parse_people",
        "type": "function",
        "name": "Extract Count",
        "func": "msg.payload = msg.payload.inside_count || 0;\nreturn msg;",
        "outputs": 1,
        "x": 330,
        "y": 360,
        "wires": [["text_people"]]
    },
    {
        "id": "parse_heartbeat",
        "type": "function",
        "name": "Heartbeat Fmt",
        "func": "msg.payload = '✅ Alive (' + new Date().toLocaleTimeString() + ')';\nreturn msg;",
        "outputs": 1,
        "x": 330,
        "y": 440,
        "wires": [["text_hb"]]
    },
    {
        "id": "parse_detection",
        "type": "function",
        "name": "Parse AI Detection",
        "func": "var p = msg.payload;\nvar type = p.type || 'Clear';\nvar conf = ((p.confidence || 0) * 100).toFixed(0) + '%';\nvar text, color;\nif (type === 'Fire') {\n    text = '🔥 FIRE DETECTED';\n    color = '#f44336';\n} else if (type === 'Smoke') {\n    text = '💨 SMOKE DETECTED';\n    color = '#9e9e9e';\n} else {\n    text = '✅ Clear';\n    color = '#4caf50';\n}\nvar status = {payload: '<font style=\"font-size:20px;font-weight:bold;color:' + color + ';\">' + text + ' (' + conf + ')</font>'};\nvar toast = null;\nif (type === 'Fire' || type === 'Smoke') {\n    toast = {payload: '⚠️ AI Camera: ' + type + ' detected! (' + conf + ')'};\n}\nreturn [status, toast];",
        "outputs": 2,
        "x": 330,
        "y": 520,
        "wires": [["text_ai_detection"], ["toast_detection"]]
    },
    {
        "id": "parse_manual",
        "type": "function",
        "name": "Parse Manual Alarm",
        "func": "var p = msg.payload;\nvar room = p.room || 'Unknown';\nvar active = p.active;\nvar text, color;\nif (active) {\n    text = '🚨 ' + room + ' — ALARM ACTIVE';\n    color = '#f44336';\n} else {\n    text = '✅ ' + room + ' — Cleared';\n    color = '#4caf50';\n}\nmsg.payload = '<font style=\"font-size:16px;font-weight:bold;color:' + color + ';\">' + text + '</font>';\nreturn msg;",
        "outputs": 1,
        "x": 330,
        "y": 600,
        "wires": [["text_manual_status"]]
    },
    {
        "id": "log_detection",
        "type": "function",
        "name": "Log AI Detection",
        "func": "var p = msg.payload;\nvar ts = new Date().toLocaleTimeString();\nmsg.payload = '[' + ts + '] AI Detection: ' + (p.type || 'Clear') + ' | Confidence: ' + ((p.confidence||0)*100).toFixed(0) + '%';\nreturn msg;",
        "outputs": 1,
        "x": 330,
        "y": 560,
        "wires": [["ui_log"]]
    },
    {
        "id": "log_manual",
        "type": "function",
        "name": "Log Manual Alarm",
        "func": "var p = msg.payload;\nvar ts = new Date().toLocaleTimeString();\nmsg.payload = '[' + ts + '] Manual Alarm: ' + (p.room || '?') + ' | Active: ' + (p.active ? 'YES' : 'NO');\nreturn msg;",
        "outputs": 1,
        "x": 330,
        "y": 640,
        "wires": [["ui_log"]]
    },
    {
        "id": "parse_water",
        "type": "function",
        "name": "Extract Water",
        "func": "var water = msg.payload.water || {};\nvar level = {payload: parseFloat(water.level_pct) || 0};\nreturn [level];",
        "outputs": 1,
        "x": 330,
        "y": 100,
        "wires": [["gauge_water"]]
    },
    {
        "id": "log_event",
        "type": "function",
        "name": "Format Log",
        "func": "var p = msg.payload;\nvar ts = new Date().toLocaleTimeString();\nvar line = '[' + ts + '] State: ' + (p.state||'?') + ' | Confidence: ' + ((p.confidence||0)*100).toFixed(0) + '% | Source: ' + (p.source||'?');\nif (p.actions) {\n  line += ' | Valve:' + p.actions.gas_valve + ' Doors:' + p.actions.doors + ' Buzzer:' + p.actions.buzzer;\n  line += ' | Pump1:' + (p.actions.pump1||'?') + ' Pump2:' + (p.actions.pump2||'?');\n}\nmsg.payload = line;\nreturn msg;",
        "outputs": 1,
        "x": 330,
        "y": 300,
        "wires": [["ui_log"]]
    },
