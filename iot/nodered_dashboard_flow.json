        "name": "Event Log",
        "group": "grp_log",
        "order": 1,
        "width": "12",
        "height": "6",
        "format": "<div id=\"sffs-log\" style=\"height:200px;overflow-y:auto;font-family:monospace;font-size:12px;background:#1a1a2e;color:#e0e0e0;padding:8px;border-radius:4px;\"></div>\n<script>\n(function(scope) {\n    scope.$watch('msg', function(msg) {\n        if (msg && msg.payload) {\n            var el = document.getElementById('sffs-log');\n            if (el) {\n                var line = document.createElement('div');\n                line.textContent = msg.payload;\n                // Color based on content\n                if (msg.payload.indexOf('FIRE') !== -1) line.style.color = '#ff4444';\n                else if (msg.payload.indexOf('GAS_LEAK') !== -1) line.style.color = '#ff9800';\n                else if (msg.payload.indexOf('SMOKE') !== -1) line.style.color = '#9e9e9e';\n                else if (msg.payload.indexOf('SAFE') !== -1) line.style.color = '#4caf50';\n                el.appendChild(line);\n                el.scrollTop = el.scrollHeight;\n                // Keep max 100 entries\n                while (el.childNodes.length > 100) el.removeChild(el.firstChild);\n            }\n        }\n    });\n})(scope);\n</script>",
        "storeOutMessages": false,
