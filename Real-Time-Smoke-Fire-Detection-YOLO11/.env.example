TELEGRAM_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX # Token for Telegram Bot API
TELEGRAM_CHAT_ID=XXXXXXXXXX          # Optional default Telegram chat ID
ENCRYPTION_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX # Key used for encryption

# MQTT Broker Settings (Mosquitto)
MQTT_BROKER_HOST=localhost          # IP or hostname of the Mosquitto broker
MQTT_BROKER_PORT=1883               # MQTT broker port (default: 1883)

# Integrated System Settings
VIDEO_SOURCE_ID=0                   # Camera index (0 = default webcam)
OCCUPANCY_LINE_X=300                # X-coordinate for the entry/exit boundary line
